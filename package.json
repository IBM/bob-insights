  "repository": {
    "type": "git",
    "url": "https://github.com/IBM/bob-insights.git"
  },
  "bugs": {
    "url": "https://github.com/IBM/bob-insights/issues"
  },
  "homepage": "https://github.com/IBM/bob-insights#readme",
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}