{
  "name": "@ibm/bob-insights-mcp",
  "version": "1.0.0",
  "description": "MCP server to get insights from your local Bob conversation history",
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "bob-insights-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
